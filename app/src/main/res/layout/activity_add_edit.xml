<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="@color/colorPrimary"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Предмет -->
        <EditText
            android:id="@+id/etSubject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Название предмета"
            android:inputType="textCapSentences"
            android:layout_marginBottom="12dp" />

        <!-- Преподаватель -->
        <EditText
            android:id="@+id/etTeacher"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ФИО преподавателя"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp" />

        <!-- Аудитория -->
        <EditText
            android:id="@+id/etRoom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Номер аудитории"
            android:inputType="text"
            android:layout_marginBottom="12dp" />

        <!-- День недели (Spinner) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="День недели:"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <!-- Время начала -->
        <EditText
            android:id="@+id/etStartTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Время начала (ЧЧ:ММ)"
            android:inputType="time"
            android:layout_marginBottom="12dp" />

        <!-- Время конца -->
        <EditText
            android:id="@+id/etEndTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Время конца (ЧЧ:ММ)"
            android:inputType="time"
            android:layout_marginBottom="16dp" />

        <!-- Кнопка Сохранить -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white" />

    </LinearLayout>
</ScrollView>